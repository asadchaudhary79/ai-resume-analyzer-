# AI-Powered Resume Analyzer — Environment variables
# Copy this file to .env and fill in your values.

# App
APP_NAME=AI-Powered Resume Analyzer API
DEBUG=false
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_analyzer

# Redis (used in Phase 5 for Celery)
REDIS_URL=redis://localhost:6379/0

# Uploads
# UPLOAD_DIR=uploads
# MAX_UPLOAD_SIZE_MB=5

# CORS (comma-separated origins; use * for public API)
# CORS_ORIGINS=*

# OpenAI (Phase 3 — leave empty until then)
OPENAI_API_KEY=
